{
  "name": "@bananos/database",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "check": "tsc -b --pretty false",
    "migrate:dev": "prisma migrate dev --schema prisma/schema.prisma",
    "migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "migrate:status": "prisma migrate status --schema prisma/schema.prisma",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "seed": "tsx prisma/seed.ts",
    "test": "tsc -b --pretty false"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "prisma": "^6.2.1",
    "typescript": "^5.7.3"
  }
}
