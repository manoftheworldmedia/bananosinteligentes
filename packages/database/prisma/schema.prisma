generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  DEPROVISIONED
}

enum PrincipalType {
  USER
  SERVICE_ACCOUNT
}

enum ConsentState {
  REQUESTED
  GRANTED
  DENIED
  REVOKED
  EXPIRED
  SUSPENDED
}

enum PolicyEffect {
  ALLOW
  DENY
}

enum PolicyStatus {
  DRAFT
  ACTIVE
  DEPRECATED
  ARCHIVED
}

enum AuditOutcome {
  SUCCESS
  DENIED
  FAILURE
}

enum ObjectOwnerType {
  CLIENT
  BANANOS
  PUBLIC
  PARTNER
  MIXED
}

enum DataClass {
  RAW
  CANONICAL
  ARTIFACT
  MEMORY
  AUDIT
  OPERATIONAL
}

enum FileAssetStatus {
  PENDING_UPLOAD
  UPLOADED
  PROCESSING
  VALIDATED
  REJECTED
  FAILED
  ARCHIVED
}

enum FileAssetKind {
  SPREADSHEET
  PDF
  IMAGE
  DOCUMENT
  TEXT
  OTHER
}

enum DatasetStatus {
  DRAFT
  VALIDATING
  ACTIVE
  QUARANTINED
  ARCHIVED
}

enum ProcessingJobType {
  METADATA_EXTRACTION
  OCR
  PARSE_SPREADSHEET
  PARSE_PDF
  PARSE_IMAGE
  VALIDATE_FILE
  CREATE_DATASET
}

enum ProcessingJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum ValidationSeverity {
  INFO
  WARNING
  ERROR
}

enum LineageEventType {
  UPLOADED
  VERSION_CREATED
  METADATA_EXTRACTED
  OCR_COMPLETED
  PARSED
  VALIDATED
  DATASET_CREATED
  GOVERNANCE_DECISION
  JOB_STATUS_CHANGED
}

enum BillingPolicyStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum MarkupRuleType {
  ORGANIZATION
  PLAN
  FEATURE
  MODEL_PROVIDER
  TOKEN_TYPE
  FILE_PROCESSING_TYPE
  REPORT_TYPE
  INGESTION_TYPE
  FIXED_MONTHLY_PLATFORM_FEE
  USAGE_TIER
  OVERAGE_RULE
  ENTERPRISE_CUSTOM
  PARTNER_PRICING
}

enum MarkupMethod {
  PERCENTAGE
  MULTIPLIER
  FIXED_UNIT_PRICE
  FIXED_AMOUNT
}

enum UsageEventType {
  TOKEN
  FILE_PROCESSING
  REPORT
  INSIGHT_GENERATION
  INGESTION
  MANUAL_ADJUSTMENT
}

enum BillingPeriodStatus {
  OPEN
  CLOSED
  INVOICED
  VOID
}

enum BudgetCapMode {
  NONE
  SOFT
  HARD
}

enum UsageAlertStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum UsageExportAudience {
  CLIENT
  INTERNAL
}

enum LedgerEntryType {
  USAGE
  CREDIT
  REFUND
  ADJUSTMENT
  PLATFORM_FEE
  COMPED
  DEMO
}

enum OverageStatus {
  NONE
  APPROACHING
  OVERAGE
  BLOCKED
}

enum InsightArtifactType {
  FINDING
  RECOMMENDATION
  FORECAST
  BENCHMARK
  RISK_SCORE
  PLAYBOOK
  HYPOTHESIS
  EXPERIMENT_RESULT
  ALERT
  MODEL_EVALUATION
}

enum InsightScope {
  TENANT
  COHORT
  NETWORK
  GLOBAL
  INTERNAL
}

enum InsightStatus {
  DRAFT
  GENERATED
  UNDER_REVIEW
  APPROVED
  PUBLISHED
  DEPRECATED
  RECALLED
  ARCHIVED
}

enum InsightRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum InsightGenerationMethod {
  HUMAN_AUTHORED
  RULE_BASED
  STATISTICAL
  MODEL_GENERATED
  HYBRID
  NETWORK_AGGREGATION
}

enum InsightReviewDecision {
  REQUESTED
  APPROVED
  REJECTED
  CHANGES_REQUESTED
  RECALLED
}

enum EvidenceType {
  CANONICAL_RECORD
  AGGREGATED_METRIC
  GRAPH_PATH
  PRIOR_INSIGHT
  PUBLIC_RESEARCH
  EXPERT_NOTE
  MODEL_OUTPUT
  EXPERIMENT_RESULT
  WEATHER_DATA
  GEOSPATIAL_DATA
}

enum RevocationBehavior {
  RETAIN_TENANT_ONLY
  RECOMPUTE
  REDACT
  RECALL
  ARCHIVE
}

enum GraphPartition {
  TENANT
  SHARED_CONCEPT
  INSIGHTS
  NETWORK_PROJECTION
  INTERNAL
}

enum GraphRecordStatus {
  PROPOSED
  ACTIVE
  DEPRECATED
  RECALLED
  ARCHIVED
}

enum GraphProposalDecision {
  PENDING
  APPROVED
  REJECTED
  APPLIED
}

enum GraphProjectionStatus {
  DRAFT
  BUILDING
  ACTIVE
  SUSPENDED
  ARCHIVED
}

enum GraphOutboxStatus {
  PENDING
  PROCESSING
  PUBLISHED
  FAILED
}

enum ConversationStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum ChatMessageRole {
  SYSTEM
  USER
  ASSISTANT
  TOOL
}

enum ChatMessageStatus {
  PENDING
  COMPLETED
  FAILED
  BLOCKED
}

enum AiRiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum AiTraceStatus {
  STARTED
  COMPLETED
  FAILED
  BLOCKED
}

enum ToolInvocationStatus {
  REQUESTED
  RUNNING
  SUCCEEDED
  FAILED
  DENIED
}

enum MemoryType {
  CONVERSATION
  USER
  TENANT
  ENTITY
  AGRONOMIC
  NETWORK
}

enum MemoryScope {
  SESSION
  USER
  ROLE
  TEAM
  FARM
  BLOCK
  CROP_CYCLE
  TENANT
  COHORT
  NETWORK
  GLOBAL
}

enum MemoryValidationStatus {
  PENDING
  VALIDATED
  STALE
  CONFLICTED
  REVOKED
  DELETED
}

enum ReportArtifactStatus {
  REQUESTED
  GENERATING
  READY
  FAILED
  ARCHIVED
}

model Tenant {
  id                   String                 @id @default(uuid()) @db.Uuid
  slug                 String                 @unique
  name                 String
  status               TenantStatus           @default(ACTIVE)
  dataResidency        String?                @map("data_residency")
  metadata             Json                   @default("{}")
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")
  organizationUnits    OrganizationUnit[]
  users                User[]
  serviceAccounts      ServiceAccount[]
  roles                Role[]
  permissions          Permission[]
  roleAssignments      RoleAssignment[]
  consentGrants        ConsentGrant[]
  policies             Policy[]
  auditEvents          AuditEvent[]
  objectRecords        ObjectRecord[]
  fileAssets           FileAsset[]
  datasets             Dataset[]
  processingJobs       ProcessingJob[]
  validationIssues     ValidationIssue[]
  lineageEvents        LineageEvent[]
  billingPolicies      ClientBillingPolicy[]
  usageEvents          UsageEvent[]
  usageRollups         UsageRollup[]
  billingPeriods       BillingPeriod[]
  invoiceLineItems     InvoiceLineItem[]
  clientUsageSummaries ClientUsageSummary[]
  internalCostLedger   InternalCostLedger[]
  clientBillableLedger ClientBillableLedger[]
  budgetPolicies       BudgetPolicy[]
  usageAlerts          UsageAlert[]
  usageExports         UsageExport[]
  insightArtifacts     InsightArtifact[]
  graphNodes           GraphNode[]
  graphEdges           GraphEdge[]
  graphChangeProposals GraphChangeProposal[]
  graphProjections     GraphProjection[]
  graphOutboxEvents    GraphOutboxEvent[]
  conversations        Conversation[]
  chatMessages         ChatMessage[]
  memories             MemoryEntry[]
  aiTraces             AiTrace[]
  toolInvocations      ToolInvocation[]
  reportArtifacts      ReportArtifact[]
  promptTemplates      PromptTemplate[]
  modelProfiles        ModelProfile[]

  @@map("tenants")
}

model OrganizationUnit {
  id        String             @id @default(uuid()) @db.Uuid
  tenantId  String             @map("tenant_id") @db.Uuid
  parentId  String?            @map("parent_id") @db.Uuid
  name      String
  type      String
  metadata  Json               @default("{}")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent    OrganizationUnit?  @relation("OrganizationUnitTree", fields: [parentId], references: [id])
  children  OrganizationUnit[] @relation("OrganizationUnitTree")
  users     User[]

  @@index([tenantId])
  @@map("organization_units")
}

model User {
  id                   String                 @id @default(uuid()) @db.Uuid
  tenantId             String                 @map("tenant_id") @db.Uuid
  organizationUnitId   String?                @map("organization_unit_id") @db.Uuid
  email                String
  displayName          String                 @map("display_name")
  passwordHash         String?                @map("password_hash")
  status               UserStatus             @default(INVITED)
  lastLoginAt          DateTime?              @map("last_login_at")
  metadata             Json                   @default("{}")
  createdAt            DateTime               @default(now()) @map("created_at")
  updatedAt            DateTime               @updatedAt @map("updated_at")
  tenant               Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  organizationUnit     OrganizationUnit?      @relation(fields: [organizationUnitId], references: [id])
  roleAssignments      RoleAssignment[]
  refreshTokens        RefreshToken[]
  usageEvents          UsageEvent[]
  internalCostLedger   InternalCostLedger[]
  clientBillableLedger ClientBillableLedger[]
  conversations        Conversation[]
  chatMessages         ChatMessage[]
  memories             MemoryEntry[]
  aiTraces             AiTrace[]
  toolInvocations      ToolInvocation[]
  reportArtifacts      ReportArtifact[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

model ServiceAccount {
  id              String           @id @default(uuid()) @db.Uuid
  tenantId        String           @map("tenant_id") @db.Uuid
  name            String
  description     String?
  keyHash         String           @map("key_hash")
  status          UserStatus       @default(ACTIVE)
  metadata        Json             @default("{}")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roleAssignments RoleAssignment[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("service_accounts")
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String?          @map("tenant_id") @db.Uuid
  key         String
  name        String
  description String?
  isSystem    Boolean          @default(false) @map("is_system")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  tenant      Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  assignments RoleAssignment[]

  @@unique([tenantId, key])
  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String?          @map("tenant_id") @db.Uuid
  key         String
  resource    String
  action      String
  description String?
  isSystem    Boolean          @default(false) @map("is_system")
  createdAt   DateTime         @default(now()) @map("created_at")
  tenant      Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles       RolePermission[]

  @@unique([tenantId, key])
  @@index([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model RoleAssignment {
  id               String          @id @default(uuid()) @db.Uuid
  tenantId         String          @map("tenant_id") @db.Uuid
  principalType    PrincipalType   @map("principal_type")
  userId           String?         @map("user_id") @db.Uuid
  serviceAccountId String?         @map("service_account_id") @db.Uuid
  roleId           String          @map("role_id") @db.Uuid
  scope            Json            @default("{}")
  createdAt        DateTime        @default(now()) @map("created_at")
  user             User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  serviceAccount   ServiceAccount? @relation(fields: [serviceAccountId], references: [id], onDelete: Cascade)
  role             Role            @relation(fields: [roleId], references: [id], onDelete: Cascade)
  tenant           Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, principalType])
  @@index([userId])
  @@index([serviceAccountId])
  @@map("role_assignments")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model ConsentGrant {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String         @map("tenant_id") @db.Uuid
  state          ConsentState   @default(REQUESTED)
  dataScope      Json           @map("data_scope")
  permittedUses  String[]       @map("permitted_uses")
  grantedBy      String?        @map("granted_by") @db.Uuid
  effectiveAt    DateTime?      @map("effective_at")
  expiresAt      DateTime?      @map("expires_at")
  revokedAt      DateTime?      @map("revoked_at")
  revocationRule Json           @default("{}") @map("revocation_rule")
  metadata       Json           @default("{}")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  objectRecords  ObjectRecord[]
  fileAssets     FileAsset[]
  datasets       Dataset[]

  @@index([tenantId, state])
  @@map("consent_grants")
}

model Policy {
  id          String       @id @default(uuid()) @db.Uuid
  tenantId    String?      @map("tenant_id") @db.Uuid
  key         String
  version     Int
  status      PolicyStatus @default(DRAFT)
  effect      PolicyEffect
  resource    String
  action      String
  conditions  Json         @default("{}")
  description String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  tenant      Tenant?      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key, version])
  @@index([tenantId, status])
  @@index([resource, action])
  @@map("policies")
}

model AuditEvent {
  id             String         @id @default(uuid()) @db.Uuid
  tenantId       String?        @map("tenant_id") @db.Uuid
  actorType      PrincipalType? @map("actor_type")
  actorId        String?        @map("actor_id") @db.Uuid
  action         String
  resource       String
  resourceId     String?        @map("resource_id")
  outcome        AuditOutcome
  policyDecision Json?          @map("policy_decision")
  metadata       Json           @default("{}")
  requestId      String?        @map("request_id")
  ipAddress      String?        @map("ip_address")
  userAgent      String?        @map("user_agent")
  hash           String?
  createdAt      DateTime       @default(now()) @map("created_at")
  tenant         Tenant?        @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([action, resource])
  @@map("audit_events")
}

model ObjectRecord {
  id              String             @id @default(uuid()) @db.Uuid
  tenantId        String             @map("tenant_id") @db.Uuid
  bucket          String
  objectKey       String             @map("object_key")
  contentType     String?            @map("content_type")
  byteSize        BigInt?            @map("byte_size")
  checksum        String?
  ownerType       ObjectOwnerType    @map("owner_type")
  ownerId         String?            @map("owner_id")
  dataClass       DataClass          @map("data_class")
  visibilityScope String             @map("visibility_scope")
  consentGrantId  String?            @map("consent_grant_id") @db.Uuid
  metadata        Json               @default("{}")
  createdAt       DateTime           @default(now()) @map("created_at")
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  consentGrant    ConsentGrant?      @relation(fields: [consentGrantId], references: [id], onDelete: SetNull)
  fileAssets      FileAsset[]
  fileVersions    FileAssetVersion[]

  @@unique([bucket, objectKey])
  @@index([tenantId, dataClass])
  @@map("object_records")
}

model Dataset {
  id               String            @id @default(uuid()) @db.Uuid
  tenantId         String            @map("tenant_id") @db.Uuid
  name             String
  description      String?
  status           DatasetStatus     @default(DRAFT)
  ownerType        ObjectOwnerType   @map("owner_type")
  visibilityScope  String            @map("visibility_scope")
  consentGrantId   String?           @map("consent_grant_id") @db.Uuid
  schemaSnapshot   Json?             @map("schema_snapshot")
  metadata         Json              @default("{}")
  createdBy        String?           @map("created_by") @db.Uuid
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  consentGrant     ConsentGrant?     @relation(fields: [consentGrantId], references: [id], onDelete: SetNull)
  fileAssets       FileAsset[]
  processingJobs   ProcessingJob[]
  validationIssues ValidationIssue[]
  lineageEvents    LineageEvent[]

  @@index([tenantId, status])
  @@map("datasets")
}

model FileAsset {
  id                String               @id @default(uuid()) @db.Uuid
  tenantId          String               @map("tenant_id") @db.Uuid
  datasetId         String?              @map("dataset_id") @db.Uuid
  objectRecordId    String?              @map("object_record_id") @db.Uuid
  consentGrantId    String?              @map("consent_grant_id") @db.Uuid
  filename          String
  contentType       String?              @map("content_type")
  byteSize          BigInt?              @map("byte_size")
  checksum          String?
  kind              FileAssetKind        @default(OTHER)
  status            FileAssetStatus      @default(PENDING_UPLOAD)
  version           Int                  @default(1)
  ownerType         ObjectOwnerType      @map("owner_type")
  dataClass         DataClass            @default(RAW) @map("data_class")
  visibilityScope   String               @map("visibility_scope")
  sourceLabel       String?              @map("source_label")
  metadata          Json                 @default("{}")
  extractedMetadata Json                 @default("{}") @map("extracted_metadata")
  validationSummary Json                 @default("{}") @map("validation_summary")
  createdBy         String?              @map("created_by") @db.Uuid
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")
  tenant            Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  dataset           Dataset?             @relation(fields: [datasetId], references: [id], onDelete: SetNull)
  objectRecord      ObjectRecord?        @relation(fields: [objectRecordId], references: [id], onDelete: SetNull)
  consentGrant      ConsentGrant?        @relation(fields: [consentGrantId], references: [id], onDelete: SetNull)
  versions          FileAssetVersion[]
  processingJobs    ProcessingJob[]
  validationIssues  ValidationIssue[]
  lineageEvents     LineageEvent[]
  chatAttachments   ChatFileAttachment[]

  @@index([tenantId, status])
  @@index([tenantId, kind])
  @@index([datasetId])
  @@map("file_assets")
}

model FileAssetVersion {
  id             String        @id @default(uuid()) @db.Uuid
  fileAssetId    String        @map("file_asset_id") @db.Uuid
  objectRecordId String?       @map("object_record_id") @db.Uuid
  version        Int
  checksum       String?
  byteSize       BigInt?       @map("byte_size")
  metadata       Json          @default("{}")
  createdBy      String?       @map("created_by") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at")
  fileAsset      FileAsset     @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)
  objectRecord   ObjectRecord? @relation(fields: [objectRecordId], references: [id], onDelete: SetNull)

  @@unique([fileAssetId, version])
  @@map("file_asset_versions")
}

model ProcessingJob {
  id           String              @id @default(uuid()) @db.Uuid
  tenantId     String              @map("tenant_id") @db.Uuid
  fileAssetId  String?             @map("file_asset_id") @db.Uuid
  datasetId    String?             @map("dataset_id") @db.Uuid
  type         ProcessingJobType
  status       ProcessingJobStatus @default(QUEUED)
  queueName    String              @map("queue_name")
  attempts     Int                 @default(0)
  maxAttempts  Int                 @default(3) @map("max_attempts")
  scheduledAt  DateTime            @default(now()) @map("scheduled_at")
  startedAt    DateTime?           @map("started_at")
  completedAt  DateTime?           @map("completed_at")
  errorCode    String?             @map("error_code")
  errorMessage String?             @map("error_message")
  payload      Json                @default("{}")
  result       Json                @default("{}")
  createdAt    DateTime            @default(now()) @map("created_at")
  updatedAt    DateTime            @updatedAt @map("updated_at")
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fileAsset    FileAsset?          @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)
  dataset      Dataset?            @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([fileAssetId])
  @@index([datasetId])
  @@map("processing_jobs")
}

model ValidationIssue {
  id          String             @id @default(uuid()) @db.Uuid
  tenantId    String             @map("tenant_id") @db.Uuid
  fileAssetId String?            @map("file_asset_id") @db.Uuid
  datasetId   String?            @map("dataset_id") @db.Uuid
  severity    ValidationSeverity
  code        String
  message     String
  path        String?
  metadata    Json               @default("{}")
  createdAt   DateTime           @default(now()) @map("created_at")
  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fileAsset   FileAsset?         @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)
  dataset     Dataset?           @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([tenantId, severity])
  @@index([fileAssetId])
  @@index([datasetId])
  @@map("validation_issues")
}

model LineageEvent {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String           @map("tenant_id") @db.Uuid
  fileAssetId String?          @map("file_asset_id") @db.Uuid
  datasetId   String?          @map("dataset_id") @db.Uuid
  eventType   LineageEventType @map("event_type")
  sourceRef   Json?            @map("source_ref")
  targetRef   Json?            @map("target_ref")
  metadata    Json             @default("{}")
  createdBy   String?          @map("created_by") @db.Uuid
  createdAt   DateTime         @default(now()) @map("created_at")
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fileAsset   FileAsset?       @relation(fields: [fileAssetId], references: [id], onDelete: Cascade)
  dataset     Dataset?         @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@index([tenantId, eventType])
  @@index([fileAssetId])
  @@index([datasetId])
  @@map("lineage_events")
}

model AiProvider {
  id             String                  @id @default(uuid()) @db.Uuid
  key            String                  @unique
  name           String
  status         String                  @default("ACTIVE")
  metadata       Json                    @default("{}")
  createdAt      DateTime                @default(now()) @map("created_at")
  updatedAt      DateTime                @updatedAt @map("updated_at")
  models         AiModel[]
  priceSchedules ProviderPriceSchedule[]
  internalCosts  InternalCostLedger[]

